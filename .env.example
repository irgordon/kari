# ==============================================================================
# GO BACKEND (API) CONFIGURATION
# ==============================================================================

# Standard PostgreSQL password
DB_PASSWORD=

# 256-bit Hex Key for AES-GCM Encryption (must be exactly 64 hex characters)
# Used by: api/internal/core/services/crypto_service.go
ENCRYPTION_KEY=

# Secret for signing and verifying JWT Access/Refresh tokens
# Used by: Go API and React frontend
JWT_SECRET=

# ==============================================================================
# RUST AGENT (MUSCLE) CONFIGURATION
# ==============================================================================

# Numeric UID the Go API container runs as (for SO_PEERCRED verification)
KARI_API_UID=1001

# Path where the Rust Agent listens for the Go API
AGENT_SOCKET=/var/run/kari/agent.sock

# Deployment paths (Agent internals)
KARI_WEB_ROOT=/var/www/kari
KARI_SYSTEMD_DIR=/etc/systemd/system

# ==============================================================================
# FRONTEND (REACT) CONFIGURATION
# ==============================================================================

# Internal Docker DNS for server-side API calls (e.g., dev.sh, docker-compose)
INTERNAL_API_URL=http://api:8080

# Public URL for browser-side fetches and redirects
PUBLIC_API_URL=http://localhost:8080
